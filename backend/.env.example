# Self-Evolving Multi-Agent AI Research Assistant - Configuration

# 1. API Keys & LLM Orchestration
GROQ_API_KEY=gsk_your_groq_api_key_goes_here

# 2. Database Integration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/self_evolving?retryWrites=true&w=majority

# 3. Security & Authentication (Firebase API keys for frontend, backend verification)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id

# 4. Communications & Alerts
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# 5. Core Settings
PORT=8000
ENVIRONMENT=development
JWT_SECRET=super_secret_galaxy_core_code_jwt_key
